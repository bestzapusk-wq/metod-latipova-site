# Скопируй этот файл в .env.local и заполни своими значениями.
# .env.local никогда не попадает в git и на фронтенд — безопасно хранить токен.

# Токен бота, полученный в @BotFather (команда /newbot)
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Chat ID, куда будут падать заявки из "Базы материалов".
# Это может быть твой личный chat_id или chat_id отдельного админ-чата/группы.
# Как узнать chat_id: напиши боту @userinfobot или добавь бота в группу
# и посмотри обновления через https://api.telegram.org/bot<ТОКЕН>/getUpdates
TELEGRAM_ADMIN_CHAT_ID=123456789

# Ссылка на твою группу "Сообщество" (с темами/topics)
NEXT_PUBLIC_COMMUNITY_URL=https://t.me/+your_invite_link_here
